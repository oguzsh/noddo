{
  "$schema": "https://raw.githubusercontent.com/nicegui-toolkit/nicegui-toolkit/main/tauri.conf.schema.json",
  "productName": "Noddo",
  "version": "0.1.0",
  "identifier": "com.noddo.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "permission",
        "title": "Noddo",
        "url": "/",
        "width": 400,
        "height": 460,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true,
        "resizable": false,
        "transparent": true,
        "shadow": false,
        "center": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
